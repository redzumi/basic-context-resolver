{
  "name": "basic-context-resolver",
  "version": "1.0.5",
  "description": "Cross-platform desktop context resolver — detects active app, browser URL, UI state (macOS, Windows, Linux)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/index.cjs",
    "dist/index.js",
    "dist/index.cjs.map",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.cts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "dotenv -e .env -- tsup --watch --onSuccess 'node dist/cli.cjs'",
    "start": "dotenv -e .env -- node dist/cli.cjs",
    "release": "release-it",
    "prepublishOnly": "tsup"
  },
  "license": "MIT",
  "dependencies": {
    "get-windows": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.0",
    "release-it": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "context",
    "desktop",
    "active-window",
    "browser-url",
    "cross-platform",
    "macos",
    "windows",
    "linux"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redzumi/basic-context-resolver.git"
  },
  "homepage": "https://github.com/redzumi/basic-context-resolver#readme"
}
